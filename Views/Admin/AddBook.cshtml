@model GyanGanga.Web.Models.Classes.Book

@{
    ViewData["Title"] = "Add Book";
}

<style>
    .add-book-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 50px);
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 20px;
    }

    .add-book-container {
        width: 100%;
        max-width: 600px;
    }

    .add-book-card {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        border: none;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .add-book-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }

        .add-book-card .card-header {
            background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%);
            color: #ffffff;
            text-align: center;
            padding: 20px;
            border-bottom: none;
        }

        .add-book-card .card-title {
            font-size: 1.8rem;
            font-weight: 600;
            margin: 0;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
        }

        .add-book-card .card-body {
            padding: 30px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-weight: 500;
            color: #333;
            margin-bottom: 5px;
            display: block;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 1rem;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }

            .form-group input:focus,
            .form-group select:focus {
                border-color: #4CAF50;
                box-shadow: 0 0 8px rgba(76, 175, 80, 0.2);
                outline: none;
            }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 5px;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 30px;
    }

        .form-actions button,
        .form-actions a {
            padding: 12px 30px;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .form-actions .btn-submit {
            background-color: #4CAF50;
            border-color: #4CAF50;
            color: #ffffff;
        }

            .form-actions .btn-submit:hover {
                background-color: #388E3C;
                border-color: #388E3C;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
            }

        .form-actions .btn-cancel {
            background-color: #6c757d;
            border-color: #6c757d;
            color: #ffffff;
        }

            .form-actions .btn-cancel:hover {
                background-color: #5a6268;
                border-color: #5a6268;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(108, 117, 125, 0.3);
            }
</style>

<div class="add-book-page">
    <div class="add-book-container">
        <div class="card add-book-card">
            <div class="card-header">
                <h2 class="card-title">Add New Book</h2>
            </div>
            <div class="card-body">
                <form asp-action="AddBook" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label asp-for="BookTitle" class="form-label">Book Title</label>
                        <input asp-for="BookTitle" class="form-control" placeholder="Enter the book title" required />
                        <span asp-validation-for="BookTitle" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookAuthor" class="form-label">Author</label>
                        <input asp-for="BookAuthor" class="form-control" placeholder="Enter the author's name" required />
                        <span asp-validation-for="BookAuthor" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookGenre" class="form-label">Genre</label>
                        <select asp-for="BookGenre" class="form-control" required>
                            <option value="">Select Genre</option>
                            <option value="Fiction">Fiction</option>
                            <option value="Non-Fiction">Non-Fiction</option>
                            <option value="Dystopian">Dystopian</option>
                            <option value="Mystery">Mystery</option>
                            <option value="Sci-Fi">Sci-Fi</option>
                        </select>
                        <span asp-validation-for="BookGenre" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookPrice" class="form-label">Price (Rs)</label>
                        <input asp-for="BookPrice" class="form-control" type="number" step="0.01" placeholder="Enter the price in Rs" required />
                        <span asp-validation-for="BookPrice" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookFormat" class="form-label">Format</label>
                        <select asp-for="BookFormat" class="form-control" required>
                            <option value="">Select Format</option>
                            <option value="Hardcover">Hardcover</option>
                            <option value="Paperback">Paperback</option>
                            <option value="Ebook">Ebook</option>
                        </select>
                        <span asp-validation-for="BookFormat" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookStock" class="form-label">Stock</label>
                        <input asp-for="BookStock" class="form-control" type="number" placeholder="Enter stock quantity" required />
                        <span asp-validation-for="BookStock" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BookIsbn" class="form-label">ISBN</label>
                        <input asp-for="BookIsbn" class="form-control" placeholder="Enter the ISBN" required />
                        <span asp-validation-for="BookIsbn" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="coverImage" class="form-label">Book Cover Image</label>
                        <input type="file" name="coverImage" class="form-control" accept="image/*" />
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Add Book</button>
                        <a href="@Url.Action("Books", "Admin")" class="btn-cancel">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>
}