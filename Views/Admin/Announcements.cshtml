@model List<GyanGanga.Web.Models.Classes.Announcement>

    @{
    ViewData["Title"] = "Manage Announcements";
    }

    <style>
        /* Ensure the page takes up the full viewport height */
        .announcements-page {
            min-height: calc(100vh - 50px); /* Adjust for footer height */
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
            padding: 30px 20px;
            display: flex;
            justify-content: flex-start; /* Align content to the left */
            align-items: flex-start; /* Align content to the top */
        }

        /* Container for the announcements, shifted left */
        .announcements-container {
            width: 90%; /* Reduced width to fit within viewport */
            max-width: 1100px; /* Adjusted max-width for better fit */
            margin: 0 0 0 50px; /* Shift left with margin */
            display: flex;
            flex-direction: column;
            align-items: flex-start; /* Align content to the left */
        }

        /* Header section */
        .announcements-header {
            text-align: left; /* Align header text to the left */
            margin-bottom: 40px;
        }

            .announcements-header h2 {
                font-size: 2.2rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 20px;
                position: relative;
            }

                .announcements-header h2::after {
                    content: '';
                    width: 60px;
                    height: 4px;
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                    position: absolute;
                    bottom: -10px;
                    left: 0; /* Align underline to the left */
                    border-radius: 2px;
                }

        /* Create announcement button */
        .admin-action {
            text-align: left; /* Align button to the left */
            margin-bottom: 40px;
        }

            .admin-action a {
                display: inline-block;
                padding: 12px 30px;
                border-radius: 8px;
                font-size: 1rem;
                font-weight: 600;
                color: #ffffff;
                background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                text-decoration: none;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

                .admin-action a:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
                }

        /* No announcements message */
        .alert-info {
            max-width: 600px;
            background-color: #d1ecf1;
            color: #0c5460;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            text-align: left; /* Align text to the left */
        }

        /* Table container with vertical scroll */
        .table-container {
            max-height: 600px; /* Adjust height as needed */
            overflow-y: auto; /* Enable vertical scrolling */
            overflow-x: auto; /* Enable horizontal scrolling if needed */
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            width: 100%; /* Ensure it takes the full width of the container */
        }

        /* Table styling */
        .announcement-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 1rem; /* Slightly larger font for readability */
        }

            .announcement-table th,
            .announcement-table td {
                padding: 15px 20px; /* Increased padding for larger cells */
                text-align: left;
                border-bottom: 1px solid #ddd;
                min-width: 100px; /* Minimum width for columns to ensure spacing */
            }

            .announcement-table th {
                background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                color: #ffffff;
                font-weight: 600;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            .announcement-table tbody tr:hover {
                background-color: #f8f9fa;
            }

            /* Status styling */
            .announcement-table .status-active {
                color: #4CAF50; /* Green for active status */
                font-weight: 500;
            }

            .announcement-table .status-inactive {
                color: #dc3545; /* Red for inactive status */
                font-weight: 500;
            }

            /* Actions buttons */
            .announcement-table .actions {
                display: flex;
                gap: 10px;
            }

                .announcement-table .actions a,
                .announcement-table .actions button {
                    padding: 8px 15px;
                    border-radius: 5px;
                    font-size: 0.9rem;
                    font-weight: 600;
                    color: #ffffff;
                    text-decoration: none;
                    border: none;
                    cursor: pointer;
                    transition: transform 0.2s ease, box-shadow 0.2s ease;
                }

                .announcement-table .actions .btn-edit {
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                }

                    .announcement-table .actions .btn-edit:hover {
                        transform: translateY(-1px);
                        box-shadow: 0 3px 10px rgba(76, 175, 80, 0.3);
                    }

                .announcement-table .actions .btn-delete {
                    background: linear-gradient(90deg, #dc3545 0%, #c82333 100%); /* Red gradient */
                }

                    .announcement-table .actions .btn-delete:hover {
                        transform: translateY(-1px);
                        box-shadow: 0 3px 10px rgba(220, 53, 69, 0.3);
                    }
    </style>

    <div class="announcements-page">
        <div class="announcements-container">
            <div class="announcements-header">
                <h2>Manage Announcements</h2>
            </div>
            <div class="admin-action">
                <a href="@Url.Action("CreateAnnouncement", "Admin")">Create New Announcement</a>
            </div>
            @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No announcements found.
            </div>
        }
        else
        {
            <div class="table-container">
                <table class="announcement-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Content</th>
                            <th>Posted Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var announcement in Model)
                        {
                        <tr>
                            <td>@announcement.AnnouncementId</td>
                            <td>@announcement.Title</td>
                            <td>@announcement.Content</td>
                            <td>@announcement.PostedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="@(announcement.IsActive ? "status-active" : "status-inactive")">
                                @(announcement.IsActive ? "Active" : "Inactive")
                            </td>
                            <td class="actions">
                                <a href="@Url.Action("EditAnnouncement", "Admin", new { id = announcement.AnnouncementId })" class="btn-edit">Edit</a>
                                <form asp-action="DeleteAnnouncement" asp-route-id="@announcement.AnnouncementId" method="post" class="d-inline">
                                    <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this announcement?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        </div>
    </div>
