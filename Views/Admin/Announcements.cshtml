@model List<GyanGanga.Web.Models.Classes.Announcement>

@{
    ViewData["Title"] = "Manage Announcements";
}

<style>
    /* Ensure the page takes up the full viewport height */
    .announcements-page {
        min-height: calc(100vh - 50px); /* Adjust for footer height */
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
        padding: 30px 20px;
    }

    /* Container for the announcements */
    .announcements-container {
        width: 100%;
        max-width: 1200px; /* Wider container for better layout of multiple cards */
        margin: 0 auto;
    }

    /* Header section */
    .announcements-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .announcements-header h2 {
        font-size: 2.2rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 20px;
        position: relative;
    }

    .announcements-header h2::after {
        content: '';
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 2px;
    }

    /* Create announcement button */
    .admin-action {
        text-align: center;
        margin-bottom: 40px;
    }

    .admin-action a {
        display: inline-block;
        padding: 12px 30px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        color: #ffffff;
        background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%);
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .admin-action a:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
    }

    /* No announcements message */
    .alert-info {
        max-width: 600px;
        margin: 0 auto;
        background-color: #d1ecf1;
        color: #0c5460;
        border-radius: 8px;
        padding: 15px;
        font-size: 1rem;
        text-align: center;
    }

    /* Announcement list styling */
    .announcement-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); /* Responsive grid */
        gap: 30px;
    }

    /* Announcement card styling */
    .announcement-card {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
        padding: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .announcement-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
    }

    .announcement-card .title {
        font-size: 1.6rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .announcement-card .content {
        font-size: 1rem;
        color: #666;
        margin-bottom: 15px;
        line-height: 1.6;
    }

    .announcement-card .posted-date {
        font-size: 0.9rem;
        color: #999;
        margin-bottom: 10px;
    }

    .announcement-card .status {
        font-size: 0.95rem;
        font-weight: 500;
        color: #4CAF50;
        margin-bottom: 15px;
    }

    .announcement-card .status.inactive {
        color: #dc3545; /* Red for inactive status */
    }

    /* Actions (buttons) */
    .announcement-card .actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-top: 20px;
    }

    .announcement-card .actions a,
    .announcement-card .actions button {
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        color: #ffffff;
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
    }

    .announcement-card .actions .btn-edit {
        background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%);
    }

    .announcement-card .actions .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
    }

    .announcement-card .actions .btn-delete {
        background: linear-gradient(90deg, #dc3545 0%, #c82333 100%);
    }

    .announcement-card .actions .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
    }
</style>

<div class="announcements-page">
    <div class="announcements-container">
        <div class="announcements-header">
            <h2>Manage Announcements</h2>
        </div>
        <div class="admin-action">
            <a href="@Url.Action("CreateAnnouncement", "Admin")">Create New Announcement</a>
        </div>
        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No announcements found.
            </div>
        }
        else
        {
            <div class="announcement-list">
                @foreach (var announcement in Model)
                {
                    <div class="announcement-card">
                        <h5 class="title">@announcement.Title</h5>
                        <p class="content">@announcement.Content</p>
                        <p class="posted-date">Posted: @announcement.PostedDate.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="status @(announcement.IsActive ? "" : "inactive")">
                            Status: @(announcement.IsActive ? "Active" : "Inactive")
                        </p>
                        <div class="actions">
                            <a href="@Url.Action("EditAnnouncement", "Admin", new { id = announcement.AnnouncementId })" class="btn-edit">Edit</a>
                            <form asp-action="DeleteAnnouncement" asp-route-id="@announcement.AnnouncementId" method="post" class="d-inline">
                                <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this announcement?')">Delete</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>