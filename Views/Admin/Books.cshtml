@model List<GyanGanga.Web.Models.Classes.ShowBook>

    @{
    ViewData["Title"] = "Manage Books";
    }

    <style>
        /* Ensure the page takes up the full viewport height */
        .books-page {
            min-height: calc(100vh - 50px); /* Adjust for footer height */
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
            padding: 30px 20px;
        }

        /* Container for the books */
        .books-container {
            width: 100%;
            max-width: 1200px; /* Wider container for better layout of multiple cards */
            margin: 0 auto;
        }

        /* Header section */
        .books-header {
            text-align: center;
            margin-bottom: 40px;
        }

            .books-header h2 {
                font-size: 2.2rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 20px;
                position: relative;
            }

                .books-header h2::after {
                    content: '';
                    width: 60px;
                    height: 4px;
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                    position: absolute;
                    bottom: -10px;
                    left: 50%;
                    transform: translateX(-50%);
                    border-radius: 2px;
                }

        /* Add new book button */
        .admin-action {
            text-align: center;
            margin-bottom: 40px;
        }

            .admin-action a {
                display: inline-block;
                padding: 12px 30px;
                border-radius: 8px;
                font-size: 1rem;
                font-weight: 600;
                color: #ffffff;
                background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                text-decoration: none;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

                .admin-action a:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
                }

        /* No books message */
        .alert-info {
            max-width: 600px;
            margin: 0 auto;
            background-color: #d1ecf1;
            color: #0c5460;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            text-align: center;
        }

        /* Book list styling */
        .book-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); /* Responsive grid */
            gap: 30px;
        }

        /* Book card styling */
        .book-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
            padding: 20px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .book-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
            }

            .book-card img {
                width: 100%;
                max-width: 200px;
                height: 200px;
                object-fit: cover;
                border-radius: 10px;
                margin-bottom: 15px;
            }

            .book-card .title {
                font-size: 1.4rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 10px;
                text-align: center;
                line-height: 1.3;
            }

            .book-card .author {
                font-size: 0.95rem;
                color: #666;
                margin-bottom: 10px;
                text-align: center;
            }

            .book-card .rating {
                color: #f39c12;
                font-size: 1.1rem;
                margin-bottom: 10px;
                text-align: center;
            }

                .book-card .rating i {
                    margin-right: 3px;
                }

            .book-card .price {
                font-size: 1.2rem;
                font-weight: 700;
                color: #4CAF50; /* Green for admin theme */
                margin-bottom: 15px;
                text-align: center;
            }

            /* Actions (buttons) */
            .book-card .actions {
                display: flex;
                gap: 15px;
                justify-content: center;
                margin-top: 15px;
            }

                .book-card .actions a,
                .book-card .actions button {
                    padding: 10px 20px;
                    border-radius: 8px;
                    font-size: 0.95rem;
                    font-weight: 600;
                    color: #ffffff;
                    text-decoration: none;
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                    border: none;
                }

                .book-card .actions .btn-edit {
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                }

                    .book-card .actions .btn-edit:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
                    }

                .book-card .actions .btn-delete {
                    background: linear-gradient(90deg, #dc3545 0%, #c82333 100%); /* Red gradient */
                }

                    .book-card .actions .btn-delete:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
                    }
    </style>

    <div class="books-page">
        <div class="books-container">
            <div class="books-header">
                <h2>Manage Books</h2>
            </div>
            <div class="admin-action">
                <a href="@Url.Action("AddBook", "Admin")">Add New Book</a>
            </div>
            @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No books found.
            </div>
        }
        else
        {
            <div class="book-list">
                @foreach (var book in Model)
                {
                <div class="book-card">
                    <img src="https://via.placeholder.com/300x200?text=@(book.BookTitle)" alt="@(book.BookTitle)">
                    <h5 class="title">@book.BookTitle</h5>
                    <p class="author">@book.BookAuthor</p>
                    <div class="rating">
                        @{
                                int fullStars = (int)book.Rating;
                                bool hasHalfStar = book.Rating - fullStars >= 0.5m; // Changed 0.5 to 0.5m (decimal literal)
                                for (int i = 0; i < fullStars; i++)
                                {
                            <i class="fas fa-star"></i>
                                }
                                if (hasHalfStar)
                                {
                            <i class="fas fa-star-half-alt"></i>
                                    fullStars++;
                                }
                                for (int i = fullStars; i < 5; i++)
                                {
                            <i class="far fa-star"></i>
                                }
                        }
                        <span>(@book.Rating)</span>
                    </div>
                    <p class="price">NPR @((book.BookPrice * 133).ToString("N2"))</p>
                    <div class="actions">
                        <a href="@Url.Action("EditBook", "Admin", new { id = book.BookId })" class="btn-edit">Edit</a>
                        <form asp-action="DeleteBook" asp-route-id="@book.BookId" method="post" class="d-inline">
                            <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this book?')">Delete</button>
                        </form>
                    </div>
                </div>
                }
            </div>
        }
        </div>
    </div>
