@model List<(GyanGanga.Web.Models.Classes.CartBook CartItem, GyanGanga.Web.Models.Classes.Book Book)>

    @{
    ViewData["Title"] = "Manage Carts";
    }

    <style>
        /* Ensure the page takes up the full viewport height */
        .carts-page {
            min-height: calc(100vh - 50px); /* Adjust for footer height */
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
            padding: 30px 20px;
        }

        /* Container for the cart items */
        .carts-container {
            width: 100%;
            max-width: 1200px; /* Wider container for better layout of multiple cards */
            margin: 0 auto;
        }

        /* Header section */
        .carts-header {
            text-align: center;
            margin-bottom: 40px;
        }

            .carts-header h2 {
                font-size: 2.2rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 20px;
                position: relative;
            }

                .carts-header h2::after {
                    content: '';
                    width: 60px;
                    height: 4px;
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                    position: absolute;
                    bottom: -10px;
                    left: 50%;
                    transform: translateX(-50%);
                    border-radius: 2px;
                }

        /* No cart items message */
        .alert-info {
            max-width: 600px;
            margin: 0 auto;
            background-color: #d1ecf1;
            color: #0c5460;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            text-align: center;
        }

        /* Cart list styling */
        .cart-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); /* Responsive grid */
            gap: 30px;
        }

        /* Cart item card styling */
        .cart-item {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
            padding: 20px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .cart-item:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
            }

            .cart-item img {
                width: 100%;
                max-width: 200px;
                height: 150px;
                object-fit: cover;
                border-radius: 10px;
                margin-bottom: 15px;
            }

            .cart-item .title {
                font-size: 1.4rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 10px;
                text-align: center;
                line-height: 1.3;
            }

            .cart-item .user {
                font-size: 0.95rem;
                color: #666;
                margin-bottom: 10px;
                text-align: center;
            }

            .cart-item .quantity {
                font-size: 0.95rem;
                color: #4CAF50; /* Green for admin theme */
                font-weight: 500;
                margin-bottom: 10px;
                text-align: center;
            }

            .cart-item .price {
                font-size: 0.95rem;
                color: #333;
                font-weight: 500;
                margin-bottom: 15px;
                text-align: center;
            }

            /* Actions (buttons) */
            .cart-item .actions {
                display: flex;
                justify-content: center;
                margin-top: 15px;
            }

                .cart-item .actions button {
                    padding: 10px 20px;
                    border-radius: 8px;
                    font-size: 0.95rem;
                    font-weight: 600;
                    color: #ffffff;
                    background: linear-gradient(90deg, #dc3545 0%, #c82333 100%); /* Red gradient for delete */
                    border: none;
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                }

                    .cart-item .actions button:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
                    }
    </style>

    <div class="carts-page">
        <div class="carts-container">
            <div class="carts-header">
                <h2>Manage Carts</h2>
            </div>
            @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No cart items found.
            </div>
        }
        else
        {
            <div class="cart-list">
                @foreach (var item in Model)
                {
                <div class="cart-item">
                    <img src="https://via.placeholder.com/300x150?text=@(item.Book.BookTitle)" alt="@(item.Book.BookTitle)">
                    <h5 class="title">@item.Book.BookTitle</h5>
                    <p class="user">User ID: @item.CartItem.UserId</p>
                    <p class="quantity">Quantity: @item.CartItem.Quantity</p>
                    <p class="price">Price: $@item.Book.BookPrice</p>
                    <div class="actions">
                        <form asp-action="DeleteCartItem" asp-route-bookId="@item.CartItem.BookId" asp-route-userId="@item.CartItem.UserId" method="post">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this cart item?')">Delete</button>
                        </form>
                    </div>
                </div>
                }
            </div>
        }
        </div>
    </div>

    @section Scripts {
        <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    }
