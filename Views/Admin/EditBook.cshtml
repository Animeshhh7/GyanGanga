@model GyanGanga.Web.Models.Classes.Book

@{
    ViewData["Title"] = "Edit Book";
}

<style>
    .admin-container {
        padding: 20px;
        max-width: 600px;
        margin: 0 auto;
    }

    .form-container {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
            display: block;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ddd;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

            .form-group input:focus, .form-group select:focus {
                border-color: #4A90E2;
                box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
                outline: none;
            }

    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

        .form-actions button, .form-actions a {
            padding: 10px 20px;
            border-radius: 25px;
            border: none;
            font-weight: 600;
            color: #ffffff;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .form-actions .btn-submit {
            background: #4A90E2;
        }

            .form-actions .btn-submit:hover {
                background: #3A80D2;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            }

        .form-actions .btn-cancel {
            background: #6c757d;
        }

            .form-actions .btn-cancel:hover {
                background: #5a6268;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            }
</style>

<div class="admin-container">
    <h2 class="section-title">Edit Book</h2>
    <div class="form-container">
        <form asp-action="EditBook" method="post">
            <input type="hidden" asp-for="BookId" />
            <div class="form-group">
                <label asp-for="BookTitle">Title</label>
                <input asp-for="BookTitle" class="form-control" required />
                <span asp-validation-for="BookTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookAuthor">Author</label>
                <input asp-for="BookAuthor" class="form-control" required />
                <span asp-validation-for="BookAuthor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookGenre">Genre</label>
                <select asp-for="BookGenre" class="form-control" required>
                    <option value="">Select Genre</option>
                    <option value="Fiction">Fiction</option>
                    <option value="Non-Fiction">Non-Fiction</option>
                    <option value="Dystopian">Dystopian</option>
                    <option value="Mystery">Mystery</option>
                    <option value="Sci-Fi">Sci-Fi</option>
                </select>
                <span asp-validation-for="BookGenre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookPrice">Price (USD)</label>
                <input asp-for="BookPrice" class="form-control" type="number" step="0.01" required />
                <span asp-validation-for="BookPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookFormat">Format</label>
                <select asp-for="BookFormat" class="form-control" required>
                    <option value="">Select Format</option>
                    <option value="Hardcover">Hardcover</option>
                    <option value="Paperback">Paperback</option>
                    <option value="Ebook">Ebook</option>
                </select>
                <span asp-validation-for="BookFormat" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookStock">Stock</label>
                <input asp-for="BookStock" class="form-control" type="number" required />
                <span asp-validation-for="BookStock" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookIsbn">ISBN</label>
                <input asp-for="BookIsbn" class="form-control" required />
                <span asp-validation-for="BookIsbn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Rating">Rating</label>
                <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="5" required />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-submit">Save Changes</button>
                <a href="@Url.Action("Books", "Admin")" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>
}