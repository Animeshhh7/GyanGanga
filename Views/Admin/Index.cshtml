@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    /* Ensure the page takes up the full viewport height */
    .dashboard-page {
        min-height: calc(100vh - 50px); /* Adjust for footer height */
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
        padding: 30px 20px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* Container for the dashboard */
    .dashboard-container {
        width: 100%;
        max-width: 1200px; /* Wider container for better layout of cards */
        margin: 0 auto;
    }

    /* Header section */
    .dashboard-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .dashboard-header h2 {
            font-size: 2.2rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
            position: relative;
        }

            .dashboard-header h2::after {
                content: '';
                width: 60px;
                height: 4px;
                background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                border-radius: 2px;
            }

    /* Dashboard cards layout */
    .admin-dashboard {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;
        margin-bottom: 40px;
    }

    /* Top row for Total Books and Total Users */
    .dashboard-top-row {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    /* Bottom row for Total Cart Items */
    .dashboard-bottom-row {
        display: flex;
        justify-content: center;
    }

    /* Dashboard card styling */
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
        padding: 25px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 300px; /* Fixed width for consistency */
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }

        .dashboard-card h3 {
            font-size: 1.6rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 15px;
        }

        .dashboard-card p {
            font-size: 2.2rem;
            font-weight: 700;
            color: #4CAF50; /* Green for admin theme */
            margin-bottom: 20px;
        }

        .dashboard-card a {
            padding: 10px 25px;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            color: #ffffff;
            background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
            text-decoration: none;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .dashboard-card a:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
            }
</style>

<div class="dashboard-page">
    <div class="dashboard-container">
        <div class="dashboard-header">
            <h2>Admin Dashboard</h2>
        </div>
        <div class="admin-dashboard">
            <!-- Top Row: Total Books and Total Users -->
            <div class="dashboard-top-row">
                <div class="dashboard-card">
                    <h3>Total Books</h3>
                    <p>@ViewBag.TotalBooks</p>
                    <a href="@Url.Action("Books", "Admin")">Manage Books</a>
                </div>
                <div class="dashboard-card">
                    <h3>Total Users</h3>
                    <p>@ViewBag.TotalUsers</p>
                    <a href="@Url.Action("Users", "Admin")">Manage Users</a>
                </div>
            </div>
            <!-- Bottom Row: Total Cart Items -->
            <div class="dashboard-bottom-row">
                <div class="dashboard-card">
                    <h3>Total Cart Items</h3>
                    <p>@ViewBag.TotalCartItems</p>
                    <a href="@Url.Action("Carts", "Admin")">Manage Carts</a>
                </div>
            </div>
        </div>
    </div>
</div>