@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-container {
        padding: 20px;
    }

    .admin-dashboard {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 40px;
    }

    .dashboard-card {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        padding: 20px;
        width: 300px;
        text-align: center;
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        }

        .dashboard-card h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }

        .dashboard-card p {
            font-size: 2rem;
            font-weight: 700;
            color: #4A90E2;
            margin-bottom: 15px;
        }

        .dashboard-card a {
            padding: 10px 20px;
            border-radius: 25px;
            background: #4A90E2;
            border: none;
            font-weight: 600;
            color: #ffffff;
            transition: all 0.3s ease;
            text-decoration: none;
        }

            .dashboard-card a:hover {
                background: #3A80D2;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            }
</style>

<div class="admin-container">
    <h2 class="section-title">Admin Dashboard</h2>
    <div class="admin-dashboard">
        <div class="dashboard-card">
            <h3>Total Books</h3>
            <p>@ViewBag.TotalBooks</p>
            <a href="@Url.Action("Books", "Admin")">Manage Books</a>
        </div>
        <div class="dashboard-card">
            <h3>Total Users</h3>
            <p>@ViewBag.TotalUsers</p>
            <a href="@Url.Action("Users", "Admin")">Manage Users</a>
        </div>
        <div class="dashboard-card">
            <h3>Total Cart Items</h3>
            <p>@ViewBag.TotalCartItems</p>
            <a href="@Url.Action("Carts", "Admin")">Manage Carts</a>
        </div>
    </div>
</div>