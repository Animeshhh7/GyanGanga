@model List<GyanGanga.Web.Models.Views.AdminUserViewModel>
    <!-- Updated namespace -->

    @{
    ViewData["Title"] = "Manage Users";
    }

    <style>
        .admin-container {
            padding: 20px;
        }

        .user-list {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }

        .user-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            padding: 15px;
            width: 300px;
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .user-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.2);
            }

            .user-card .username {
                font-size: 1.5rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 5px;
            }

            .user-card .email {
                font-size: 1rem;
                color: #666;
                margin-bottom: 5px;
            }

            .user-card .role {
                font-size: 1rem;
                color: #4A90E2;
                margin-bottom: 10px;
            }

            .user-card .actions {
                display: flex;
                justify-content: center;
            }

                .user-card .actions button {
                    padding: 8px 15px;
                    border-radius: 25px;
                    background: #dc3545;
                    border: none;
                    font-weight: 600;
                    color: #ffffff;
                    transition: all 0.3s ease;
                }

                    .user-card .actions button:hover {
                        background: #c82333;
                        transform: translateY(-3px);
                        box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                    }
    </style>

    <div class="admin-container">
        <h2 class="section-title">Manage Users</h2>
        @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center" role="alert">
            No users found.
        </div>
    }
    else
    {
        <div class="user-list">
            @foreach (var user in Model)
            {
            <div class="user-card">
                <h5 class="username">@user.UserName</h5>
                <p class="email">@user.Email</p>
                <p class="role">Role: @user.Role</p>
                <div class="actions">
                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                        <button type="submit" class="btn-remove" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                    </form>
                </div>
            </div>
            }
        </div>
    }
    </div>

    @section Scripts {
        <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    }
