@model List<GyanGanga.Web.Models.Views.AdminUserViewModel>

    @{
    ViewData["Title"] = "Manage Users";
    }

    <style>
        /* Ensure the page takes up the full viewport height */
        .users-page {
            min-height: calc(100vh - 50px); /* Adjust for footer height */
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
            padding: 30px 20px;
        }

        /* Container for the users */
        .users-container {
            width: 100%;
            max-width: 1200px; /* Wider container for better layout of multiple cards */
            margin: 0 auto;
        }

        /* Header section */
        .users-header {
            text-align: center;
            margin-bottom: 40px;
        }

            .users-header h2 {
                font-size: 2.2rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 20px;
                position: relative;
            }

                .users-header h2::after {
                    content: '';
                    width: 60px;
                    height: 4px;
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                    position: absolute;
                    bottom: -10px;
                    left: 50%;
                    transform: translateX(-50%);
                    border-radius: 2px;
                }

        /* No users message */
        .alert-info {
            max-width: 600px;
            margin: 0 auto;
            background-color: #d1ecf1;
            color: #0c5460;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            text-align: center;
        }

        /* User list styling */
        .user-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); /* Responsive grid */
            gap: 30px;
        }

        /* User card styling */
        .user-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
            padding: 20px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .user-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
            }

            .user-card .username {
                font-size: 1.4rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 10px;
                text-align: center;
                line-height: 1.3;
            }

            .user-card .email {
                font-size: 0.95rem;
                color: #666;
                margin-bottom: 10px;
                text-align: center;
            }

            .user-card .role {
                font-size: 0.95rem;
                color: #4CAF50; /* Green for admin theme */
                font-weight: 500;
                margin-bottom: 15px;
                text-align: center;
            }

            /* Actions (buttons) */
            .user-card .actions {
                display: flex;
                justify-content: center;
                margin-top: 15px;
            }

                .user-card .actions button {
                    padding: 10px 20px;
                    border-radius: 8px;
                    font-size: 0.95rem;
                    font-weight: 600;
                    color: #ffffff;
                    background: linear-gradient(90deg, #dc3545 0%, #c82333 100%); /* Red gradient for delete */
                    border: none;
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                }

                    .user-card .actions button:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
                    }
    </style>

    <div class="users-page">
        <div class="users-container">
            <div class="users-header">
                <h2>Manage Users</h2>
            </div>
            @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No users found.
            </div>
        }
        else
        {
            <div class="user-list">
                @foreach (var user in Model)
                {
                <div class="user-card">
                    <h5 class="username">@user.UserName</h5>
                    <p class="email">@user.Email</p>
                    <p class="role">Role: @user.Role</p>
                    <div class="actions">
                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                        </form>
                    </div>
                </div>
                }
            </div>
        }
        </div>
    </div>

    @section Scripts {
        <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    }
