@model List<GyanGanga.Web.Models.Views.AdminUserViewModel>

    @{
    ViewData["Title"] = "Manage Users";
    }

    <style>
        /* Ensure the page takes up the full viewport height */
        .users-page {
            min-height: calc(100vh - 50px); /* Adjust for footer height */
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); /* Subtle gradient background */
            padding: 30px 20px;
            display: flex;
            justify-content: flex-start; /* Align content to the left */
            align-items: flex-start; /* Align content to the top */
        }

        /* Container for the users, shifted left */
        .users-container {
            width: 90%; /* Reduced width to fit within viewport */
            max-width: 1100px; /* Adjusted max-width for better fit */
            margin: 0 0 0 50px; /* Shift left with margin */
            display: flex;
            flex-direction: column;
            align-items: flex-start; /* Align content to the left */
        }

        /* Header section */
        .users-header {
            text-align: left; /* Align header text to the left */
            margin-bottom: 40px;
        }

            .users-header h2 {
                font-size: 2.2rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 20px;
                position: relative;
            }

                .users-header h2::after {
                    content: '';
                    width: 60px;
                    height: 4px;
                    background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green underline */
                    position: absolute;
                    bottom: -10px;
                    left: 0; /* Align underline to the left */
                    border-radius: 2px;
                }

        /* Search and Filter Section */
        .search-filter-section {
            background: #ffffff;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            width: 100%;
        }

        .search-bar {
            display: flex;
            align-items: center;
            position: relative;
            margin-bottom: 20px;
        }

            .search-bar i {
                position: absolute;
                left: 15px;
                color: #4A90E2;
                font-size: 1.2rem;
            }

            .search-bar input {
                padding: 12px 20px 12px 40px;
                border-radius: 25px;
                border: 1px solid #ddd;
                font-size: 1rem;
                width: 100%;
                transition: all 0.3s ease;
            }

                .search-bar input:focus {
                    border-color: #4A90E2;
                    box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
                    outline: none;
                }

        .filter-panel {
            display: flex;
            padding: 20px 0;
            gap: 20px;
            flex-wrap: wrap;
        }

            .filter-panel select {
                padding: 12px 20px;
                border-radius: 25px;
                border: 1px solid #ddd;
                font-size: 1rem;
                width: 200px;
                transition: all 0.3s ease;
            }

                .filter-panel select:focus {
                    border-color: #4A90E2;
                    box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
                    outline: none;
                }

            .filter-panel .btn-primary {
                padding: 12px 30px;
                border-radius: 25px;
                background: #4A90E2;
                border: none;
                font-weight: 600;
                color: #ffffff;
                transition: all 0.3s ease;
            }

                .filter-panel .btn-primary:hover {
                    background: #3A80D2;
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                }

            .filter-panel .btn-secondary {
                padding: 12px 30px;
                border-radius: 25px;
                background: #6c757d;
                border: none;
                font-weight: 600;
                color: #ffffff;
                transition: all 0.3s ease;
            }

                .filter-panel .btn-secondary:hover {
                    background: #5a6268;
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                }

        /* No users message */
        .alert-info {
            max-width: 600px;
            background-color: #d1ecf1;
            color: #0c5460;
            border-radius: 8px;
            padding: 15px;
            font-size: 1rem;
            text-align: left; /* Align text to the left */
        }

        /* Table container with vertical scroll */
        .table-container {
            max-height: 600px; /* Adjust height as needed */
            overflow-y: auto; /* Enable vertical scrolling */
            overflow-x: auto; /* Enable horizontal scrolling if needed */
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            width: 100%; /* Ensure it takes the full width of the container */
        }

        /* Table styling */
        .user-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 1rem; /* Slightly larger font for readability */
        }

            .user-table th,
            .user-table td {
                padding: 15px 20px; /* Increased padding for larger cells */
                text-align: left;
                border-bottom: 1px solid #ddd;
                min-width: 100px; /* Minimum width for columns to ensure spacing */
            }

            .user-table th {
                background: linear-gradient(90deg, #4CAF50 0%, #388E3C 100%); /* Green gradient */
                color: #ffffff;
                font-weight: 600;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            .user-table tbody tr:hover {
                background-color: #f8f9fa;
            }

            /* Actions buttons */
            .user-table .actions {
                display: flex;
                gap: 10px;
            }

                .user-table .actions button {
                    padding: 8px 15px;
                    border-radius: 5px;
                    font-size: 0.9rem;
                    font-weight: 600;
                    color: #ffffff;
                    background: linear-gradient(90deg, #dc3545 0%, #c82333 100%); /* Red gradient for delete */
                    border: none;
                    cursor: pointer;
                    transition: transform 0.2s ease, box-shadow 0.2s ease;
                }

                    .user-table .actions button:hover {
                        transform: translateY(-1px);
                        box-shadow: 0 3px 10px rgba(220, 53, 69, 0.3);
                    }
    </style>

    <div class="users-page">
        <div class="users-container">
            <div class="users-header">
                <h2>Manage Users</h2>
            </div>
            <!-- Search and Filter Section -->
            <div class="search-filter-section">
                <form method="get" asp-action="Users">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" name="search" placeholder="Search by Username or Email..." class="form-control" value="@ViewBag.Search" />
                    </div>
                    <div class="filter-panel">
                        <select name="role" class="form-select">
                            <option value="">All Roles</option>
                            @if (ViewBag.Role == "Admin")
                        {
                            <option value="Admin" selected>Admin</option>
                        }
                        else
                        {
                            <option value="Admin">Admin</option>
                        }
                            @if (ViewBag.Role == "User")
                        {
                            <option value="User" selected>User</option>
                        }
                        else
                        {
                            <option value="User">User</option>
                        }
                        </select>
                        <button type="submit" class="btn btn-primary">Apply Filter</button>
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-secondary">Reset Filter</a>
                    </div>
                </form>
            </div>
            @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No users found.
            </div>
        }
        else
        {
            <div class="table-container">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.Role</td>
                            <td class="actions">
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                    <button type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        </div>
    </div>

    @section Scripts {
        <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    }
