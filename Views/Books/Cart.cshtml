@model List<GyanGanga.Web.Models.Classes.ShowBook>

    @{
    ViewData["Title"] = "Cart";
    }

    <style>
        /* Section Titles */
        .section-title {
            font-size: 3rem;
            font-weight: 700;
            color: #333;
            margin: 60px 0 30px;
            text-align: center;
            position: relative;
        }

            .section-title::before {
                content: '';
                width: 90px;
                height: 5px;
                background: linear-gradient(90deg, #4A90E2, #3A80D2);
                position: absolute;
                bottom: -15px;
                left: 50%;
                transform: translateX(-50%);
                border-radius: 5px;
            }

        /* Cart Item Card */
        .cart-item {
            display: flex;
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            padding: 15px;
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .cart-item:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.2);
            }

            .cart-item img {
                width: 100px;
                height: 150px;
                object-fit: cover;
                border-radius: 10px;
                margin-right: 20px;
            }

        .cart-item-details {
            flex-grow: 1;
        }

            .cart-item-details .title {
                font-size: 1.5rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 5px;
            }

            .cart-item-details .author {
                font-size: 1rem;
                color: #666;
                margin-bottom: 5px;
            }

            .cart-item-details .rating {
                color: #f39c12;
                font-size: 1.1rem;
                margin-bottom: 5px;
            }

            .cart-item-details .price {
                font-size: 1.2rem;
                font-weight: 700;
                color: #4A90E2;
                margin-bottom: 5px;
            }

            .cart-item-details .total-price {
                font-size: 1.1rem;
                color: #333;
                margin-bottom: 10px;
            }

        .quantity-control {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

            .quantity-control input {
                width: 60px;
                padding: 5px;
                text-align: center;
                border: 1px solid #ddd;
                border-radius: 5px;
            }

            .quantity-control button {
                padding: 5px 10px;
                border: none;
                background: #4A90E2;
                color: #ffffff;
                border-radius: 5px;
                cursor: pointer;
                transition: all 0.3s ease;
            }

                .quantity-control button:hover {
                    background: #3A80D2;
                }

        .cart-item-actions {
            display: flex;
            gap: 10px;
        }

            .cart-item-actions .btn-remove {
                padding: 8px 15px;
                border-radius: 25px;
                background: #dc3545;
                border: none;
                color: #ffffff;
                font-weight: 600;
                transition: all 0.3s ease;
                text-decoration: none;
            }

                .cart-item-actions .btn-remove:hover {
                    background: #c82333;
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                }

        /* Cart Summary */
        .cart-summary {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            padding: 20px;
            margin-top: 20px;
            text-align: center;
        }

            .cart-summary h3 {
                font-size: 1.8rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 15px;
            }

            .cart-summary p {
                font-size: 1.2rem;
                color: #666;
                margin-bottom: 10px;
            }

            .cart-summary .btn-checkout {
                padding: 12px 30px;
                border-radius: 25px;
                background: #4A90E2;
                border: none;
                font-weight: 600;
                color: #ffffff;
                transition: all 0.3s ease;
                text-decoration: none;
                margin-right: 10px;
            }

                .cart-summary .btn-checkout:hover {
                    background: #3A80D2;
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                }

            .cart-summary .btn-continue {
                padding: 12px 30px;
                border-radius: 25px;
                background: #6c757d;
                border: none;
                font-weight: 600;
                color: #ffffff;
                transition: all 0.3s ease;
                text-decoration: none;
            }

                .cart-summary .btn-continue:hover {
                    background: #5a6268;
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.2);
                }
    </style>

    <h2 class="section-title">Your Cart</h2>
    @if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center" role="alert">
        @TempData["Success"]
    </div>
}
    @if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center" role="alert">
        @TempData["Error"]
    </div>
}
    @if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info text-center" role="alert">
        Your cart is empty.
    </div>
}
else
{
    @foreach (var book in Model)
    {
    <div class="cart-item">
        <img src="https://via.placeholder.com/100x150?text=@(book.BookTitle)" alt="@(book.BookTitle)">
        <div class="cart-item-details">
            <h5 class="title">@book.BookTitle</h5>
            <p class="author">@book.BookAuthor</p>
            <div class="rating">
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star-half-alt"></i>
                <span>(@book.Rating)</span>
            </div>
            <p class="price">NPR @(book.BookPrice * 133).ToString("N2")</p>
            <div class="quantity-control">
                <form asp-controller="Books" asp-action="UpdateCartItemQuantity" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@(book.BookId)" />
                    <button type="submit" name="quantity" value="@(book.Quantity - 1)" @(book.Quantity <= 1 ? "disabled" : "")>-</button>
                    <input type="text" value="@book.Quantity" readonly />
                    <button type="submit" name="quantity" value="@(book.Quantity + 1)">+</button>
                </form>
            </div>
            <p class="total-price">Total: NPR @((book.BookPrice * book.Quantity * 133).ToString("N2"))</p>
            <div class="cart-item-actions">
                <form asp-controller="Books" asp-action="RemoveFromCart" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@(book.BookId)" />
                    <button type="submit" class="btn-remove">Remove</button>
                </form>
            </div>
        </div>
    </div>
    }

 <!-- Cart Summary -->
    <div class="cart-summary">
        <h3>Cart Summary</h3>
        <p>Total Items: @ViewBag.TotalItems</p>
        <p>Total Price: NPR @((Convert.ToDecimal(ViewBag.TotalPrice) * 133).ToString("N2"))</p>
        <form asp-controller="Books" asp-action="Checkout" method="post" class="d-inline">
            <button type="submit" class="btn-checkout">Checkout</button>
        </form>
        <a href="@Url.Action("Index", "Books")" class="btn-continue">Continue Shopping</a>
    </div>
}
