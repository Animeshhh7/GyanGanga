@model GyanGanga.Web.Models.ViewModels.BookDetailsViewModel 
 
@{ 
    ViewData["Title"] = "Book Details"; 
} 
 
<h1>Book Details</h1> 
 
@if (Model != null) 
{ 
    <div class="card"> 
        <div class="card-body"> 
            <h5 class="card-title">@Model.Title</h5> 
            <p class="card-text"> 
                <strong>Author:</strong> @Model.Author<br /> 
                <strong>Genre:</strong> @Model.Genre<br /> 
                <strong>Price:</strong> @Model.Price.ToString("C")<br /> 
                <strong>Format:</strong> @Model.Format<br /> 
                <strong>Stock:</strong> @Model.Stock<br /> 
                <strong>ISBN:</strong> @Model.ISBN 
            </p> 
            <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Back to Catalog</a> 
        </div> 
    </div> 
} 
else 
{ 
    <p>Book not found.</p> 
    <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Back to Catalog</a> 
} 
