@model GyanGanga.Web.Models.Classes.ShowBookDetails 
<style> 
    .book-details { display: flex; align-items: flex-start; margin-bottom: 30px; } 
    .book-details img { width: 300px; height: 400px; object-fit: cover; border-radius: 5px; margin-right: 30px; } 
    .book-details .details { flex: 1; } 
    .book-details h2 { font-size: 2rem; font-weight: 700; margin-bottom: 20px; color: #333; } 
    .book-details p { font-size: 1rem; margin-bottom: 10px; color: #666; } 
    .book-details .price { font-size: 1.5rem; font-weight: 700; color: #1a3c6d; margin-bottom: 20px; } 
    .book-details form { margin-bottom: 10px; } 
</style> 
@if (Model == null) { 
    <div class="alert alert-warning" role="alert"> 
        Book not found. 
    </div> 
} else { 
    <div class="book-details"> 
        <img src="https://via.placeholder.com/300x400?text=@(Model.BookTitle)" alt="@(Model.BookTitle)"> 
        <div class="details"> 
            <h2>@Model.BookTitle</h2> 
            <p><strong>Author:</strong> @Model.BookAuthor</p> 
            <p><strong>Genre:</strong> @Model.BookGenre</p> 
            <p class="price">NPR @(Model.BookPrice * 133).ToString("N2")</p> 
            <p><strong>Format:</strong> @Model.BookFormat</p> 
            <p><strong>Stock:</strong> @Model.BookStock</p> 
            <p><strong>ISBN:</strong> @Model.BookIsbn</p> 
            <form asp-action="AddToCart" method="post" class="mb-3"> 
                <input type="hidden" name="id" value="@(Model.BookId)" /> 
                <div class="mb-3"> 
                    <label for="quantity" class="form-label">Quantity:</label> 
                    <input type="number" name="quantity" id="quantity" value="1" min="1" class="form-control w-25 d-inline" /> 
                </div> 
                <button type="submit" class="btn btn-primary">Add to Cart</button> 
            </form> 
            <form asp-action="Save" method="post"> 
                <input type="hidden" name="id" value="@(Model.BookId)" /> 
                <button type="submit" class="btn btn-secondary">Save Book</button> 
            </form> 
        </div> 
    </div> 
} 
