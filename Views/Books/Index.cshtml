@model List<GyanGanga.Web.Models.Classes.ShowBook>

    <style>
        /* Search and Filter Section */
        .search-filter-section {
            background: #ffffff;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin-bottom: 40px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            position: relative;
            margin-bottom: 20px;
        }

            .search-bar i {
                position: absolute;
                left: 15px;
                color: #4A90E2;
                font-size: 1.2rem;
            }

            .search-bar input {
                padding: 12px 20px 12px 40px;
                border-radius: 25px;
                border: 1px solid #ddd;
                font-size: 1rem;
                width: 100%;
                transition: all 0.3s ease;
            }

                .search-bar input:focus {
                    border-color: #4A90E2;
                    box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
                    outline: none;
                }

        .filter-toggle {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            cursor: pointer;
            border-bottom: 1px solid #eee;
        }

            .filter-toggle h3 {
                font-size: 1.5rem;
                font-weight: 600;
                color: #333;
                margin: 0;
            }

            .filter-toggle i {
                font-size: 1.2rem;
                color: #4A90E2;
                transition: transform 0.3s ease;
            }

                .filter-toggle i.active {
                    transform: rotate(180deg);
                }

        .filter-panel {
            display: none;
            padding: 20px 0;
            gap: 20px;
        }

            .filter-panel.active {
                display: flex;
                flex-wrap: wrap;
            }

            .filter-panel select, .filter-panel input {
                padding: 12px 20px;
                border-radius: 25px;
                border: 1px solid #ddd;
                font-size: 1rem;
                width: 200px;
                transition: all 0.3s ease;
            }

                .filter-panel select:focus, .filter-panel input:focus {
                    border-color: #4A90E2;
                    box-shadow: 0 0 8px rgba(74, 144, 226, 0.2);
                    outline: none;
                }

        .price-range {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 300px;
        }

            .price-range input[type="number"] {
                width: 100px;
            }

        .filter-panel .btn-primary {
            padding: 12px 30px;
            border-radius: 25px;
            background: #4A90E2;
            border: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .filter-panel .btn-primary:hover {
                background: #3A80D2;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            }

        .filter-panel .btn-secondary {
            padding: 12px 30px;
            border-radius: 25px;
            background: #6c757d;
            border: none;
            font-weight: 600;
            color: #ffffff;
            transition: all 0.3s ease;
        }

            .filter-panel .btn-secondary:hover {
                background: #5a6268;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            }

        /* Section Titles */
        .section-title {
            font-size: 3rem;
            font-weight: 700;
            color: #333;
            margin: 60px 0 30px;
            text-align: center;
            position: relative;
        }

            .section-title::before {
                content: '';
                width: 90px;
                height: 5px;
                background: linear-gradient(90deg, #4A90E2, #3A80D2);
                position: absolute;
                bottom: -15px;
                left: 50%;
                transform: translateX(-50%);
                border-radius: 5px;
            }

        /* Modern Book Card */
        .book-card {
            position: relative;
            background: #ffffff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            margin-bottom: 40px;
            height: 100%;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .book-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.2);
            }

            .book-card img {
                width: 100%;
                height: 320px;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

            .book-card:hover img {
                transform: scale(1.08);
            }

            .book-card .card-body {
                padding: 25px;
                text-align: center;
                background: rgba(255,255,255,0.95);
                backdrop-filter: blur(8px); /* Glassmorphism effect */
            }

            .book-card .card-title {
                font-size: 1.5rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 10px;
                height: 48px;
                overflow: hidden;
                text-overflow: ellipsis;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
            }

            .book-card .card-author {
                font-size: 1rem;
                color: #666;
                margin-bottom: 10px;
            }

            .book-card .rating {
                margin-bottom: 10px;
                color: #f39c12;
                font-size: 1.1rem;
            }

            .book-card .price {
                font-size: 1.4rem;
                font-weight: 700;
                color: #4A90E2;
                margin-bottom: 15px;
            }

            .book-card .action-buttons {
                display: flex;
                justify-content: center;
                gap: 15px;
            }

            .book-card .btn-icon {
                font-size: 1rem;
                padding: 10px;
                border-radius: 50%;
                background: #f8f9fa;
                border: 1px solid #ddd;
                color: #4A90E2;
                transition: all 0.3s ease;
            }

                .book-card .btn-icon:hover {
                    background: #4A90E2;
                    color: #ffffff;
                    transform: scale(1.1);
                    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
                }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            margin-top: 40px;
        }

            .pagination a {
                color: #4A90E2;
                padding: 10px 15px;
                margin: 0 5px;
                border-radius: 25px;
                text-decoration: none;
                transition: all 0.3s ease;
            }

                .pagination a:hover {
                    background: #4A90E2;
                    color: #ffffff;
                }

                .pagination a.active {
                    background: #4A90E2;
                    color: #ffffff;
                }
    </style>

    <!-- Search and Filter Section -->
    <div class="search-filter-section">
        <form method="get" asp-action="Index">
            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Search by Title, Author, ISBN..." class="form-control" value="@ViewBag.Search" />
            </div>
            <div class="filter-toggle" onclick="toggleFilters()">
                <h3>Filters & Sorting</h3>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="filter-panel" id="filterPanel">
                <select name="genre" class="form-select">
                    <option value="">All Genres</option>
                    @if (ViewBag.Genre == "Fiction")
                {
                    <option value="Fiction" selected>Fiction</option>
                }
                else
                {
                    <option value="Fiction">Fiction</option>
                }
                    @if (ViewBag.Genre == "Non-Fiction")
                {
                    <option value="Non-Fiction" selected>Non-Fiction</option>
                }
                else
                {
                    <option value="Non-Fiction">Non-Fiction</option>
                }
                    @if (ViewBag.Genre == "Dystopian")
                {
                    <option value="Dystopian" selected>Dystopian</option>
                }
                else
                {
                    <option value="Dystopian">Dystopian</option>
                }
                    @if (ViewBag.Genre == "Mystery")
                {
                    <option value="Mystery" selected>Mystery</option>
                }
                else
                {
                    <option value="Mystery">Mystery</option>
                }
                    @if (ViewBag.Genre == "Sci-Fi")
                {
                    <option value="Sci-Fi" selected>Sci-Fi</option>
                }
                else
                {
                    <option value="Sci-Fi">Sci-Fi</option>
                }
                </select>
                <select name="format" class="form-select">
                    <option value="">All Formats</option>
                    @if (ViewBag.Format == "Hardcover")
                {
                    <option value="Hardcover" selected>Hardcover</option>
                }
                else
                {
                    <option value="Hardcover">Hardcover</option>
                }
                    @if (ViewBag.Format == "Paperback")
                {
                    <option value="Paperback" selected>Paperback</option>
                }
                else
                {
                    <option value="Paperback">Paperback</option>
                }
                    @if (ViewBag.Format == "Ebook")
                {
                    <option value="Ebook" selected>Ebook</option>
                }
                else
                {
                    <option value="Ebook">Ebook</option>
                }
                </select>
                <div class="price-range">
                    <input type="number" name="minPrice" placeholder="Min Price" value="@ViewBag.MinPrice" min="0" step="0.01" />
                    <span>-</span>
                    <input type="number" name="maxPrice" placeholder="Max Price" value="@ViewBag.MaxPrice" min="0" step="0.01" />
                </div>
                <select name="sort" class="form-select">
                    <option value="">Sort By</option>
                    @if (ViewBag.Sort == "title_asc")
                {
                    <option value="title_asc" selected>Title (A-Z)</option>
                }
                else
                {
                    <option value="title_asc">Title (A-Z)</option>
                }
                    @if (ViewBag.Sort == "title_desc")
                {
                    <option value="title_desc" selected>Title (Z-A)</option>
                }
                else
                {
                    <option value="title_desc">Title (Z-A)</option>
                }
                    @if (ViewBag.Sort == "price_asc")
                {
                    <option value="price_asc" selected>Price (Low to High)</option>
                }
                else
                {
                    <option value="price_asc">Price (Low to High)</option>
                }
                    @if (ViewBag.Sort == "price_desc")
                {
                    <option value="price_desc" selected>Price (High to Low)</option>
                }
                else
                {
                    <option value="price_desc">Price (High to Low)</option>
                }
                    @if (ViewBag.Sort == "popularity_desc")
                {
                    <option value="popularity_desc" selected>Popularity</option>
                }
                else
                {
                    <option value="popularity_desc">Popularity</option>
                }
                </select>
                <button type="submit" class="btn btn-primary">Apply Filters</button>
                <a href="@Url.Action("Index", "Books")" class="btn btn-secondary">Reset Filters</a>
            </div>
        </form>
    </div>

    <!-- Books Catalogue -->
    <h2 class="section-title">Our Books</h2>
    @if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info text-center" role="alert">
        No books found. Try adjusting your search or filter criteria.
    </div>
}
else
{
    <div class="row">
        @foreach (var book in Model)
        {
        <div class="col-md-4">
            <div class="book-card">
                <img src="https://via.placeholder.com/300x320?text=@(book.BookTitle)" class="card-img-top" alt="@(book.BookTitle)">
                <div class="card-body">
                    <h5 class="card-title">@book.BookTitle</h5>
                    <p class="card-author">@book.BookAuthor</p>
                    <div class="rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                        <span>(@book.Rating)</span>
                    </div>
                    <p class="price">NPR @(book.BookPrice * 133).ToString("N2")</p>
                    <div class="action-buttons">
                        <form asp-controller="Books" asp-action="AddToCart" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@(book.BookId)" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn-icon" title="Add to Cart"><i class="fas fa-cart-plus"></i></button>
                        </form>
                        @if (User?.Identity?.IsAuthenticated == true)
                            {
                                if (book.IsBookmarked)
                                {
                        <form asp-controller="Books" asp-action="UnbookmarkFromBooks" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@(book.BookId)" />
                            <button type="submit" class="btn-icon" title="Unbookmark"><i class="fas fa-bookmark"></i></button>
                        </form>
                                }
                                else
                                {
                        <form asp-controller="Books" asp-action="SaveBook" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@(book.BookId)" />
                            <button type="submit" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></button>
                        </form>
                                }
                            }
                            else
                            {
                        <a href="@Url.Action("Login", "Account")" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></a>
                            }
                        <a href="@Url.Action("Details", "Books", new { id = book.BookId })" class="btn-icon" title="View Details"><i class="fas fa-eye"></i></a>
                    </div>
                </div>
            </div>
        </div>
        }
    </div>

 <!-- Pagination -->
    <div class="pagination">
        @if (ViewBag.CurrentPage > 1)
        {
        <a href="@Url.Action("Index", new { search = ViewBag.Search, sort = ViewBag.Sort, genre = ViewBag.Genre, format = ViewBag.Format, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, page = ViewBag.CurrentPage - 1 })">Previous</a>
        }
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
        <a href="@Url.Action("Index", new { search = ViewBag.Search, sort = ViewBag.Sort, genre = ViewBag.Genre, format = ViewBag.Format, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, page = i })" class="@(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
        }
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
        <a href="@Url.Action("Index", new { search = ViewBag.Search, sort = ViewBag.Sort, genre = ViewBag.Genre, format = ViewBag.Format, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, page = ViewBag.CurrentPage + 1 })">Next</a>
        }
    </div>
}

    @section Scripts {
        <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
        <script>
            function toggleFilters() {
                const filterPanel = document.getElementById('filterPanel');
                const toggleIcon = document.querySelector('.filter-toggle i');
                filterPanel.classList.toggle('active');
                toggleIcon.classList.toggle('active');
            }
        </script>
    }
