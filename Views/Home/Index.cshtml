@inject GyanGanga.Web.Services.Interfaces.IBookHelper BookHelper

@{
    ViewData["Title"] = "Gyan Ganga - Online Bookstore";
    var announcements = await BookHelper.GetAllAnnouncements();
    var activeAnnouncements = announcements.Where(a => a.IsActive).ToList();

    // Get newly added books (e.g., last 4 books by ID descending)
    var allBooks = await BookHelper.GetAllBooks();
    var newlyAddedBooks = allBooks.OrderByDescending(b => b.BookId).Take(4).ToList();

    // Get random books for "Most Demanded" (simulating popularity)
    var randomBooks = allBooks.OrderBy(x => Guid.NewGuid()).Take(4).ToList();
}

<style>
    /* Page Layout */
    .home-page {
        min-height: calc(100vh - 50px);
        background: #f7f9fc;
        padding: 20px 20px 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Main Container */
    .home-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 0 0 0; /* Align with sidebar */
        display: flex;
        flex-direction: column;
        align-items: flex-start; /* Align content to the left */
    }

    /* Announcement Banner */
    .announcement-banner {
        background: #ffffff;
        color: #2d3436;
        padding: 10px 20px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        border: 1px solid #e6f0fa;
        width: 100%;
        max-width: 900px;
        font-size: 0.9rem;
        font-weight: 500;
    }

        .announcement-banner i {
            color: #74b9ff;
            font-size: 1.2rem;
        }

        .announcement-banner .text {
            flex-grow: 1;
            text-align: left;
        }

    /* Welcome Section */
    .welcome-section {
        margin-bottom: 40px;
        text-align: left;
        width: 100%;
        max-width: 900px;
    }

        .welcome-section h1 {
            font-size: 2.8rem;
            font-weight: 700;
            color: #2d3436;
            margin-bottom: 20px;
            position: relative;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-family: 'Playfair Display', serif;
            background: linear-gradient(90deg, #74b9ff, #4a90e2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

            .welcome-section h1::before {
                content: '';
                width: 80px;
                height: 4px;
                background: linear-gradient(90deg, #74b9ff, #4a90e2);
                position: absolute;
                bottom: -10px;
                left: 0;
                border-radius: 2px;
            }

        .welcome-section p {
            font-size: 1.1rem;
            color: #666;
            line-height: 1.6;
            margin-bottom: 15px;
            font-family: 'Roboto', sans-serif;
        }

    /* Section Titles */
    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2d3436;
        margin: 20px 0;
        position: relative;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-align: left;
        font-family: 'Playfair Display', serif;
        background: linear-gradient(90deg, #74b9ff, #4a90e2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

        .section-title::before {
            content: '';
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, #74b9ff, #4a90e2);
            position: absolute;
            bottom: -10px;
            left: 0;
            border-radius: 2px;
        }

    /* Book Sections */
    .book-section {
        width: 100%;
        max-width: 1200px;
        margin-bottom: 60px;
    }

    /* Books Grid */
    .books-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr); /* 4 tiles per row */
        gap: 40px 50px; /* Vertical: 40px, Horizontal: 50px */
        width: 100%;
        max-width: 1200px;
        margin: 0 0 0 0;
    }

    /* Book Card */
    .book-card {
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
        transition: all 0.3s ease;
        border: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        aspect-ratio: 1 / 1.2; /* Adjusted aspect ratio to accommodate increased height */
        height: 360px; /* Increased height from 320px to 360px */
        background: linear-gradient(145deg, #ffffff, #f7f9fc);
    }

        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.18);
            background: linear-gradient(145deg, #f7f9fc, #ffffff);
        }

        .book-card img {
            width: 100%;
            height: 180px; /* Kept image height the same */
            object-fit: cover;
            transition: transform 0.3s ease;
            aspect-ratio: 1 / 1; /* Square aspect ratio for images */
            border-bottom: 3px solid #74b9ff;
            filter: brightness(95%);
        }

        .book-card:hover img {
            transform: scale(1.05);
            filter: brightness(100%);
        }

        .book-card .card-body {
            padding: 12px;
            text-align: center;
            width: 100%;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .book-card .card-title {
            font-size: 1rem;
            font-weight: 600;
            color: #2d3436;
            margin-bottom: 5px;
            height: 32px;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            line-height: 1.2em;
            font-family: 'Roboto', sans-serif;
        }

        .book-card .card-author {
            font-size: 0.8rem;
            color: #7f8c8d;
            margin-bottom: 5px;
            font-family: 'Roboto', sans-serif;
        }

        .book-card .rating {
            margin-bottom: 5px;
            color: #f1c40f;
            font-size: 0.9rem;
        }

        .book-card .price {
            font-size: 1rem;
            font-weight: 700;
            color: #74b9ff;
            margin-bottom: 8px;
            font-family: 'Roboto', sans-serif;
        }

        .book-card .action-buttons {
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: nowrap;
            margin-top: 10px; /* Added margin to ensure buttons are not cramped */
        }

        .book-card .btn-icon {
            font-size: 0.9rem;
            padding: 6px;
            border-radius: 50%;
            background: #f8f9fa;
            border: 1px solid #ddd;
            color: #74b9ff;
            transition: all 0.3s ease;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .book-card .btn-icon:hover {
                background: #74b9ff;
                color: #ffffff;
                transform: scale(1.1);
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            }

    /* Responsive Adjustments */
    @@media (max-width: 1200px) {
        .books-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .books-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .announcement-banner {
            position: static;
            margin: 0 auto 20px;
        }
    }

    @@media (max-width: 480px) {
        .books-grid {
            grid-template-columns: 1fr;
        }

        .welcome-section h1 {
            font-size: 2rem;
        }

        .welcome-section p {
            font-size: 1rem;
        }

        .announcement-banner {
            font-size: 0.85rem;
        }
    }
</style>

<div class="home-page">
    <div class="home-container">
        <!-- Announcement Banner -->
        @if (activeAnnouncements.Any())
        {
            foreach (var announcement in activeAnnouncements)
            {
        <div class="announcement-banner">
            <i class="fas fa-bullhorn"></i>
            <span class="text">@announcement.Title - @announcement.Content (Posted: @announcement.PostedDate.ToString("dd/MM/yyyy"))</span>
            <i class="fas fa-clock"></i>
        </div>
            }
        }

        <!-- Welcome Section -->
        <div class="welcome-section">
            <h1>Welcome to Gyan Ganga</h1>
            <p>
                At Gyan Ganga, we bring you an extensive collection of books spanning various genres, formats, and eras. Whether you're searching for the latest bestsellers, timeless classics, or hidden gems, our online bookstore has something for every reader.
            </p>
            <p>
                Browse our curated sections to discover newly added titles or explore our most demanded books. Use our intuitive search and filter tools to find exactly what you're looking for, add your favorites to your cart, and purchase them at the best prices—all from the comfort of your home.
            </p>
        </div>

        <!-- Newly Added Books -->
        <div class="book-section">
            <h2 class="section-title">Newly Added Books</h2>
            <div class="books-grid">
                @foreach (var book in newlyAddedBooks)
                {
                <div class="book-card">
                    @if (!string.IsNullOrEmpty(book.CoverImagePath))
                        {
                    <img src="@book.CoverImagePath" class="card-img-top" alt="@book.BookTitle">
                        }
                        else
                        {
                    <img src="https://via.placeholder.com/300x300?text=@book.BookTitle" class="card-img-top" alt="@book.BookTitle">
                        }
                    <div class="card-body">
                        <h5 class="card-title">@book.BookTitle</h5>
                        <p class="card-author">@book.BookAuthor</p>
                        <div class="rating">
                            @{
                                    int fullStars = (int)book.Rating;
                                    bool hasHalfStar = book.Rating - fullStars >= 0.5m;
                                    for (int i = 0; i < fullStars; i++)
                                    {
                                <i class="fas fa-star"></i>
                                    }
                                    if (hasHalfStar)
                                    {
                                <i class="fas fa-star-half-alt"></i>
                                        fullStars++;
                                    }
                                    for (int i = fullStars; i < 5; i++)
                                    {
                                <i class="far fa-star"></i>
                                    }
                            }
                            <span>(@book.Rating)</span>
                        </div>
                        <p class="price">Rs @book.BookPrice.ToString("N2")</p>
                        <div class="action-buttons">
                            <form asp-controller="Books" asp-action="AddToCart" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn-icon" title="Add to Cart"><i class="fas fa-cart-plus"></i></button>
                            </form>
                            @if (User?.Identity?.IsAuthenticated == true)
                                {
                                    if (book.IsBookmarked)
                                    {
                            <form asp-controller="Books" asp-action="UnbookmarkFromBooks" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <button type="submit" class="btn-icon" title="Unbookmark"><i class="fas fa-bookmark"></i></button>
                            </form>
                                    }
                                    else
                                    {
                            <form asp-controller="Books" asp-action="SaveBook" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <button type="submit" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></button>
                            </form>
                                    }
                                }
                                else
                                {
                            <a href="@Url.Action("Login", "Account")" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></a>
                                }
                            <a href="@Url.Action("Details", "Books", new { id = book.BookId })" class="btn-icon" title="View Details"><i class="fas fa-eye"></i></a>
                        </div>
                    </div>
                </div>
                }
            </div>
        </div>

        <!-- Most Demanded Books -->
        <div class="book-section">
            <h2 class="section-title">Most Demanded</h2>
            <div class="books-grid">
                @foreach (var book in randomBooks)
                {
                <div class="book-card">
                    @if (!string.IsNullOrEmpty(book.CoverImagePath))
                        {
                    <img src="@book.CoverImagePath" class="card-img-top" alt="@book.BookTitle">
                        }
                        else
                        {
                    <img src="https://via.placeholder.com/300x300?text=@book.BookTitle" class="card-img-top" alt="@book.BookTitle">
                        }
                    <div class="card-body">
                        <h5 class="card-title">@book.BookTitle</h5>
                        <p class="card-author">@book.BookAuthor</p>
                        <div class="rating">
                            @{
                                    int fullStars = (int)book.Rating;
                                    bool hasHalfStar = book.Rating - fullStars >= 0.5m;
                                    for (int i = 0; i < fullStars; i++)
                                    {
                                <i class="fas fa-star"></i>
                                    }
                                    if (hasHalfStar)
                                    {
                                <i class="fas fa-star-half-alt"></i>
                                        fullStars++;
                                    }
                                    for (int i = fullStars; i < 5; i++)
                                    {
                                <i class="far fa-star"></i>
                                    }
                            }
                            <span>(@book.Rating)</span>
                        </div>
                        <p class="price">Rs @book.BookPrice.ToString("N2")</p>
                        <div class="action-buttons">
                            <form asp-controller="Books" asp-action="AddToCart" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn-icon" title="Add to Cart"><i class="fas fa-cart-plus"></i></button>
                            </form>
                            @if (User?.Identity?.IsAuthenticated == true)
                                {
                                    if (book.IsBookmarked)
                                    {
                            <form asp-controller="Books" asp-action="UnbookmarkFromBooks" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <button type="submit" class="btn-icon" title="Unbookmark"><i class="fas fa-bookmark"></i></button>
                            </form>
                                    }
                                    else
                                    {
                            <form asp-controller="Books" asp-action="SaveBook" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@book.BookId" />
                                <button type="submit" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></button>
                            </form>
                                    }
                                }
                                else
                                {
                            <a href="@Url.Action("Login", "Account")" class="btn-icon" title="Bookmark"><i class="far fa-bookmark"></i></a>
                                }
                            <a href="@Url.Action("Details", "Books", new { id = book.BookId })" class="btn-icon" title="View Details"><i class="fas fa-eye"></i></a>
                        </div>
                    </div>
                </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
}